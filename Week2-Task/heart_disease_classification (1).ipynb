    "plt.show()\n",
    "\n",
    "print(classification_report(y_test, knn_predictions, target_names=[\"No Disease\", \"Disease\"]))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "af733a7d",
   "metadata": {},
   "source": [
    "## Step 8: Tune K (Hyperparameter Tuning)\n",
    "\n",
    "Instead of guessing K=5, we test a range of values and pick the one with the\n",
    "best test accuracy — the \"elbow point\" from the DecodeLabs slides."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "7922fc6f",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-07-23T10:36:53.417225Z",
     "iopub.status.busy": "2026-07-23T10:36:53.416399Z",
     "iopub.status.idle": "2026-07-23T10:36:53.775941Z",
     "shell.execute_reply": "2026-07-23T10:36:53.774758Z"
    }
   },
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x500 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Best K: 12 with accuracy 86.89%\n"
     ]
    }
   ],
   "source": [
    "k_values = range(1, 21)\n",
    "accuracies = []\n",
    "\n",
    "for k in k_values:\n",
    "    model_k = KNeighborsClassifier(n_neighbors=k)\n",
    "    model_k.fit(X_train_scaled, y_train)\n",
    "    accuracies.append(model_k.score(X_test_scaled, y_test))\n",
    "\n",
    "plt.figure(figsize=(8, 5))\n",
    "plt.plot(k_values, accuracies, marker=\"o\", color=\"teal\")\n",
    "plt.xlabel(\"K Value\")\n",
    "plt.ylabel(\"Test Accuracy\")\n",
    "plt.title(\"Accuracy vs K Value\")\n",
    "plt.xticks(list(k_values))\n",
    "plt.grid(True)\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"06_k_tuning.png\")\n",
    "plt.show()\n",
    "\n",
    "best_k = k_values[int(np.argmax(accuracies))]\n",
    "print(f\"Best K: {best_k} with accuracy {max(accuracies):.2%}\")"
   ]
  },
  {
   "cell_type": "code",
